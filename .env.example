# Copy this file to .env.local and fill in real values. Never commit .env.local.

# --- Site URL (used in email/WhatsApp links) ---
NEXT_PUBLIC_SITE_URL=https://starexlaundry.ca

# --- Supabase (Project Settings > API) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (Developers > API keys) ---
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# From the webhook endpoint's "Signing secret" once created in Developers > Webhooks,
# pointing at https://<your-domain>/api/stripe/webhook (events: payment_intent.succeeded, payment_intent.payment_failed)
STRIPE_WEBHOOK_SECRET=

# --- Admin dashboard access (/admin) ---
# Comma-separated staff emails allowed into /admin. Leave blank to instead use the
# is_admin flag on a Supabase Auth user's metadata.
ADMIN_EMAILS=

# --- Email (Resend or Postmark — pick one) ---
RESEND_API_KEY=
# POSTMARK_SERVER_TOKEN=
# Owner inbox that gets alerted on every new booking and contact-form message.
# Leave blank to disable owner alerts (customer confirmation emails are unaffected).
ADMIN_NOTIFICATION_EMAIL=

# --- Upstash Redis (REST) — rate limiting + admin-stats cache ---
# Create a database at console.upstash.com and copy the REST URL + token.
# Optional — rate limiting and stats caching no-op gracefully without it.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Native Redis (optional) — only for the BullMQ notification queue ---
# A rediss:// TCP URL. Leave blank to send notifications inline (no retries).
REDIS_URL=

# --- WhatsApp (Twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=   # e.g. whatsapp:+14155238886

# --- Sanity (CMS, added once marketing content pages are built) ---
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=

# --- CleanCloud (Phase 2+, once client subscribes to Grow/Grow+ plan) ---
CLEANCLOUD_API_KEY=
